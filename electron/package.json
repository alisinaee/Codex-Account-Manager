{
  "name": "codex-account-manager-electron",
  "version": "0.0.0",
  "private": true,
  "productName": "Codex Account Manager",
  "description": "Optional Electron desktop shell for Codex Account Manager",
  "main": "src/main.js",
  "build": {
    "appId": "com.codexaccountmanager.desktop",
    "productName": "Codex Account Manager",
    "files": [
      "src/**",
      "dist/**",
      "assets/**",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/codex-account-manager.icns"
    },
    "dmg": {
      "icon": "assets/codex-account-manager.icns"
    },
    "win": {
      "icon": "assets/codex-account-manager.png"
    },
    "linux": {
      "icon": "assets/codex-account-manager.png",
      "category": "Development"
    }
  },
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "vite build",
    "test": "node --test tests/*.test.js",
    "test:e2e": "npm run build && playwright test"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^41.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.3"
  }
}
